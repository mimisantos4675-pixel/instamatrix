# ─────────────────────────────────────────────────────────────
# InstaMatrix — Variáveis de Ambiente
# ─────────────────────────────────────────────────────────────
#
# COMO USAR:
# 1. Copie este arquivo para ".env" (apenas para desenvolvimento local)
#    cp .env.example .env
#
# 2. Na Netlify, configure via:
#    Site Settings → Environment Variables → Add a variable
#
# ─────────────────────────────────────────────────────────────

# App Secret do seu app no Meta for Developers
# Nunca exponha este valor no frontend!
META_APP_SECRET=seu_app_secret_aqui
